generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  role           Role     @default(ADMIN)
  createdAt      DateTime @default(now())
}

enum Role {
  ADMIN
}
